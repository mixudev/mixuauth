APP_NAME="MixuAuth"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
ADMIN_EMAILS=admin@example.com
TRUSTED_PROXIES=127.0.0.1,::1

# Database
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=Mixu_Auth
DB_USERNAME=app_laravel
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

MSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# Cache & Session (gunakan Redis di production)
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

# Pastikan in production password wajib ada
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIST_PASSWORD
REDIS_PORT=6379

# Queue (untuk pengiriman OTP via email yang async)
QUEUE_CONNECTION=redis

# Mail (untuk pengiriman OTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# OTP Configuration
OTP_ENABLED=true

# Security CAPTCHA (Cloudflare Turnstile recommended)
# Daftar gratis di: https://dash.cloudflare.com/?to=/:account/turnstile
# Jika Anda tidak ingin menggunakan CAPTCHA, ubah RATE_LIMIT_CHALLENGE=throttle di bawah.
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET=
CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
CAPTCHA_DEBUG_LOG=false

# Rate Limiting & Challenge Behavior
# Opsi challenge: captcha (munculkan verifikasi bot) | throttle (tolak akses berbasis waktu)
RATE_LIMIT_CHALLENGE=throttle
RATE_LIMIT_MAX_ATTEMPTS=5

# WhatsApp Gateway
# Dapatkan token dari dashboard provider (Fonnte, dsb.)
WA_FONNTE_TOKEN=your_fonnte_api_token_here

# Layanan AI FastAPI
AI_RISK_SERVICE_URL=http://fastapi-risk:8000
AI_RISK_TIMEOUT=5
AI_RISK_API_KEY=CHANGE_ME_AI_API_KEY

# Argon2id Hashing
HASH_MEMORY=65536
HASH_THREADS=1
HASH_TIME=4

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=warning
SECURITY_LOG_LEVEL=info # [L-03 FIX] Tetap catat log login/security meski aplikasi LOG_LEVEL=warning
SECURITY_LOG_DAYS=90

# Google Social Login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
