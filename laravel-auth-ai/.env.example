APP_NAME="Secure Auth"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Database
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=secure_auth
DB_USERNAME=app_user
DB_PASSWORD=secret123

# Cache & Session (gunakan Redis di production)
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# Queue (untuk pengiriman OTP via email yang async)
QUEUE_CONNECTION=redis

# Mail (untuk pengiriman OTP)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# OTP Configuration
OTP_ENABLED=true

# Layanan AI FastAPI
AI_RISK_SERVICE_URL=http://fastapi-risk:8000
AI_RISK_TIMEOUT=5
AI_RISK_API_KEY=

# Argon2id Hashing
HASH_MEMORY=65536
HASH_THREADS=1
HASH_TIME=4

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=warning
SECURITY_LOG_DAYS=90
